{
  "name": "repsclaw",
  "version": "1.0.0",
  "description": "OpenClaw Plugin System - RAG, Compliance & Crawler Services",
  "main": "dist/index.js",
  "scripts": {
    "build": "bash scripts/build.sh",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "postinstall": "node dist/cli/setup.js || tsx src/cli/setup.ts || echo 'Setup skipped'",
    "setup:openclaw": "tsx src/cli/setup.ts",
    "test": "npm run test:mount",
    "test:mount": "tsx tests/integration/simple-mount.test.ts",
    "test:integration": "tsx tests/integration/setup.test.ts",
    "test:postinstall": "tsx tests/integration/postinstall.test.ts",
    "test:all": "npm run test:mount && npm run test:integration && npm run test:postinstall",
    "pretest:ci": "npm run build",
    "test:ci": "npm run test:all"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "rag",
    "compliance",
    "crawler",
    "fastify"
  ],
  "author": "",
  "license": "MIT",
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@zodyac/zod-mongoose": "^1.1.3",
    "axios": "^1.6.8",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "fs-extra": "^11.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
